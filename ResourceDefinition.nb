Cell[CellGroupData[{

Cell[TextData[{
 "Basic Description",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"LongDescription", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Give a short paragraph explaining your paclet. This is the first \
text that users will see when visiting the main landing page of your paclet.",
          "MoreInfoText"], Background -> GrayLevel[0.95], FrameMargins -> 20, 
        FrameStyle -> GrayLevel[0.9], RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoLongDescription"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "79656655-671f-5147-9562-cfa0afe96411"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "LongDescription"},
 DefaultNewCellStyle->"Text",
 CellTags->{"Basic Description", "LongDescription", "TemplateCellGroup"},
 CellID->97826971,ExpressionUUID->"0d0c76ec-ce18-f640-97d4-c4c9f3eb1faa"],

Cell["\<\
A paclet intended to be used for interfacing with your Strava account and \
conducting data analysis on your fitness activities. It uses the Strava API. \
Please read the 'Details' section for guidance on setup.\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9881784983683395`*^9, 3.9881785620045986`*^9}, {
  3.988713639498396*^9, 3.9887136488192844`*^9}},
 CellTags->"DefaultContent",
 CellID->312061637,ExpressionUUID->"553a1453-5d39-5349-86f1-011e420b987b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Details",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"Details", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Details may include a long description of the resource's contents, \
history, methodology or other relevant information. Give references here if \
they are directly relevant to the resource. The details will appear above the \
examples on the webpage for the resource.", "MoreInfoText"], Background -> 
        GrayLevel[0.95], FrameMargins -> 20, FrameStyle -> GrayLevel[0.9], 
        RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoDetails"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "46c6807d-fdf7-ca4b-b925-cc40d78a2ff6"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "Details"},
 DefaultNewCellStyle->"Notes",
 CellTags->{"Details", "TemplateCellGroup"},
 CellID->280804237,ExpressionUUID->"1cb203ef-7677-2241-b429-d0dc0da0627b"],

Cell[TextData[{
 "See the ",
 ButtonBox["Strava Developer Docs",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://developers.strava.com/docs/getting-started/"], None},
  ButtonNote->"https://developers.strava.com/docs/getting-started/"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9881786495387383`*^9, 3.9881786711808815`*^9}, 
   3.988179228227133*^9, {3.9887446857303867`*^9, 3.9887446958800106`*^9}},
 CellID->628960940,ExpressionUUID->"4211053e-e47c-7841-88e2-56f0071e5e6e"],

Cell["\<\
In order to use this paclet, you must first follow the instructions at the \
link above for 'making an application'.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.988178600057272*^9, 3.988178636641775*^9}, {
  3.9881786762914467`*^9, 3.988178684482643*^9}, {3.988179137910948*^9, 
  3.988179150464573*^9}, {3.988179213310068*^9, 3.988179222331003*^9}, {
  3.98871362383272*^9, 3.988713626034916*^9}},
 CellTags->"DefaultContent",
 CellID->741278932,ExpressionUUID->"1ffeed11-776d-9640-8292-78fefa577a81"],

Cell[TextData[{
 "After completing the steps, navigate to this ",
 ButtonBox["link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.strava.com/settings/api"], None},
  ButtonNote->"https://www.strava.com/settings/api"],
 " for your API Application."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9889123451834984`*^9, 3.988912378229988*^9}, {
   3.989058306645075*^9, 3.9890583125305214`*^9}, 3.9890591745162964`*^9},
 CellID->145034498,ExpressionUUID->"3d959fca-1fdf-fc4e-b9b3-b352e135399c"],

Cell[TextData[{
 "You should store the following system credentials: ",
 StyleBox["SystemCredential[\"Strava-Client-ID\"]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 ",",
 StyleBox[" SystemCredential[\"Strava-Client-Secret\"]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 ", ",
 StyleBox["SystemCredential[\"Strava-Refresh-Token\"]",
  FontFamily->"Consolas",
  FontWeight->"Bold"]
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9887122105450344`*^9, 3.9887122617744637`*^9}, {
  3.9887133898910866`*^9, 3.988713392211582*^9}, {3.9887138546158485`*^9, 
  3.9887138574334908`*^9}},
 CellID->105071879,ExpressionUUID->"d5740b84-ec1b-724e-a80b-0f12fb1d3964"],

Cell["\<\
It is recommended to use a name like 'localhost' for the Authorization \
Callback Domain.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.988178686510107*^9, 3.9881787083784504`*^9}, {
  3.988179155529566*^9, 3.9881791950831547`*^9}},
 CellID->45625172,ExpressionUUID->"00285423-1839-6746-9b9f-bfc75784bc78"],

Cell[TextData[{
 "Use the paclet function ",
 StyleBox["AuthorizeStravaApplication[]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 StyleBox[", which takes optional arguments of your Redirect URI (defaults to \
\"http://localhost\"), and 'scope' (defaults to \
\"read_all,activity:read_all,profile:read_all\").",
  FontWeight->"Normal"]
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9887121633362255`*^9, 3.9887121666543865`*^9}, {
   3.98871254424654*^9, 3.988712550941309*^9}, {3.9887126076211166`*^9, 
   3.9887126079331093`*^9}, {3.988712639132595*^9, 3.9887126693581543`*^9}, {
   3.9887127037168293`*^9, 3.9887127665341854`*^9}, 3.9887380064300613`*^9},
 CellID->159295117,ExpressionUUID->"5dfd503b-18c0-9a40-81d1-2307cfdf35ae"],

Cell["\<\
This opens a browser window and you will be prompted to authorize the \
application. After authorizing, you will be redirected to a URL which \
includes your Authorization Code in the query string, (e.g., code=abc123).\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9887127802142334`*^9, 3.9887128369330635`*^9}, {
   3.9887129169715786`*^9, 3.9887129715070267`*^9}, {3.9887131338990154`*^9, 
   3.988713183331106*^9}, 3.9887132147459373`*^9, {3.9887133247296696`*^9, 
   3.9887133279218636`*^9}},
 CellID->174399260,ExpressionUUID->"1544fde4-a1b2-5f49-96cf-b055f9d3f56a"],

Cell[TextData[{
 "Store this Authorization Code as ",
 StyleBox["SystemCredential[\"Strava-Authorization-Code\"]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.988712981685356*^9, 3.9887130151226616`*^9}, {
   3.988713382298092*^9, 3.9887133852416496`*^9}, 3.9887134537552586`*^9},
 CellID->242433152,ExpressionUUID->"ad17138d-afb2-a747-ad46-0a40cbe75ab3"],

Cell[TextData[{
 "Then use the paclet function ",
 StyleBox["GenerateStravaAccessToken[]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 " to obtain an Access Token that is valid for 6 hours. This will \
automatically set the value of ",
 StyleBox["SystemCredential[\"Strava-Access-Token\"]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 StyleBox[".",
  FontFamily->"Source Sans Code",
  FontWeight->"Normal"]
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9887130429268665`*^9, 3.9887130580418415`*^9}, {
  3.988713219234833*^9, 3.988713275548687*^9}, {3.9887133527059555`*^9, 
  3.9887133631135674`*^9}, {3.988715195034998*^9, 3.9887151982202377`*^9}},
 CellID->43119554,ExpressionUUID->"1dc19f99-3fce-5b45-92d4-c0d392b8e61a"],

Cell[TextData[{
 "To obtain a new access token, use the paclet function ",
 StyleBox["RefreshAccessToken[]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 ". This will automatically update the value of ",
 StyleBox["SystemCredential[\"Strava-Access-Token\"]",
  FontFamily->"Consolas",
  FontWeight->"Bold"],
 StyleBox[".",
  FontFamily->"Source Sans Code",
  FontWeight->"Normal"]
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9887134201547737`*^9, 3.9887134550020847`*^9}, {
  3.9887135713851585`*^9, 3.988713581724497*^9}},
 CellID->154448672,ExpressionUUID->"2dc5d8fb-6d93-9b49-b4dd-6c5b25e25041"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Primary Context",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"PrimaryContext", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
         TextData[{
          "Specify the primary context of your paclet that users should load \
with ", 
           Cell[
            BoxData[
             StyleBox[
              TagBox[
               ButtonBox[
                StyleBox[
                "Needs", "SymbolsRefLink", ShowStringCharacters -> True, 
                 FontFamily -> "Source Sans Pro"], BaseStyle -> Dynamic[
                  FEPrivate`If[
                   CurrentValue["MouseOver"], {
                   "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {
                   "Link"}]], ButtonData -> "paclet:ref/Needs", 
                ContentPadding -> False], 
               MouseAppearanceTag["LinkHand"]], ShowStringCharacters -> True, 
              FontFamily -> "Source Sans Pro"]]], " or ", 
           Cell[
            BoxData[
             StyleBox[
              TagBox[
               ButtonBox[
                StyleBox[
                "Get", "SymbolsRefLink", ShowStringCharacters -> True, 
                 FontFamily -> "Source Sans Pro"], BaseStyle -> Dynamic[
                  FEPrivate`If[
                   CurrentValue["MouseOver"], {
                   "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {
                   "Link"}]], ButtonData -> "paclet:ref/Get", ContentPadding -> 
                False], 
               MouseAppearanceTag["LinkHand"]], ShowStringCharacters -> True, 
              FontFamily -> "Source Sans Pro"]]], 
           " in order to access the paclet's functionality. If your paclet is \
not meant to be loaded via a context, this section can be left blank. If \
specified, the primary context will also be displayed on the main web page \
for your paclet."}], "MoreInfoText"], Background -> GrayLevel[0.95], 
        FrameMargins -> 20, FrameStyle -> GrayLevel[0.9], RoundingRadius -> 5,
         ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoPrimaryContext"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "bebda215-4fba-be4c-b428-a527ce2ccd01"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "PrimaryContext"},
 DefaultNewCellStyle->"Text",
 CellTags->{"Primary Context", "PrimaryContext", "TemplateCellGroup"},
 CellID->944769214,ExpressionUUID->"203a1426-fdc9-8644-8b55-95b59c560b2a"],

Cell["JosephBrennan`StravaLink`", "Text",
 TaggingRules->{},
 CellID->111826772,ExpressionUUID->"bff110d2-91a7-7b40-82b9-676319f3a33b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Main Guide Page",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"MainGuidePage", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Choose one of your documentation guide pages to feature as part of \
the main landing page for your paclet. This guide page should correspond to a \
general overview of your paclet.", "MoreInfoText"], Background -> 
        GrayLevel[0.95], FrameMargins -> 20, FrameStyle -> GrayLevel[0.9], 
        RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoMainGuidePage"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "33507ddb-e11e-df47-a790-6d61407891fe"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "MainGuidePage"},
 CellTags->{"Main Guide Page", "MainGuidePage", "TemplateCellGroup"},
 CellID->501402523,ExpressionUUID->"be54c73e-c542-8f4e-b7a5-3b1a352bc5c5"],

