Cell[TextData[{
 "Visualize the segment using ",
 ButtonBox["GooglePolylineDecode",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/FunctionRepository/resources/\
GooglePolylineDecode"], None},
  ButtonNote->
   "https://resources.wolframcloud.com/FunctionRepository/resources/\
GooglePolylineDecode"],
 ":"
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.988744202866907*^9, 3.9887442436873417`*^9}},
 CellID->322263004,ExpressionUUID->"d7c90320-4354-5045-8f87-4210c2d0267e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"segment", "=", 
     RowBox[{"StravaSegment", "[", "2320922", "]"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"coords", "=", 
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<GooglePolylineDecode\>\"", "]"}], 
      "[", 
      RowBox[{"segment", "[", 
       RowBox[{"\"\<map\>\"", ",", "\"\<polyline\>\""}], "]"}], "]"}]}], 
    "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"GeoListPlot", "[", 
    RowBox[{"coords", ",", 
     RowBox[{"Joined", "->", "True"}]}], "]"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 TaggingRules->{},
