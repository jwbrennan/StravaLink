 CellID->386206736,ExpressionUUID->"d049772d-5594-5949-af93-531c478524b4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"data", "=", 
     RowBox[{"StravaActivityData", "[", "]"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Dataset", "[", 
    RowBox[{"data", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"1", ";;", "12"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<name\>\"", ",", "\"\<id\>\"", ",", "\"\<distance\>\"", 
         ",", "\"\<sport_type\>\"", ",", "\"\<start_date\>\""}], "}"}]}], 
