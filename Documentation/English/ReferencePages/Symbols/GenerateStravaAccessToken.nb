Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"29ca3c81-24d5-3445-9fce-5b6b97b9cc51"],
 Cell[BoxData[
  RowBox[{"GenerateStravaAccessToken", "[", "]"}]], "InlineFormula",
  ExpressionUUID->"e5bb5398-1646-ab4a-92b5-48c02ea77b63"],
 " \[LineSeparator]executes a request for an access token using authenticated \
athlete credentials"
}], "Usage",
 CellChangeTimes->{{3.9890573771330547`*^9, 3.9890573815247593`*^9}, {
  3.989057415123045*^9, 3.989057445217146*^9}},
 CellID->595915040,ExpressionUUID->"e9703404-3263-8844-9490-2c83c30b861b"],

Cell["\<\
This function requires that you have set the following system credentials:\
\>", "Notes",
 CellChangeTimes->{{3.98905747701108*^9, 3.9890574946325283`*^9}, 
   3.9890579543807945`*^9},
 CellID->194007686,ExpressionUUID->"96135088-e0e7-a74a-a08a-0172b39427a5"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "66f3a870-0249-244a-b80e-21df2cf795ab"], 
    RowBox[{"SystemCredential", "[", "\"\<Strava-Client-ID\>\"", "]"}]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "90d17920-43a5-f14c-b52f-4c40f045f4ba"], 
    RowBox[{"SystemCredential", "[", "\"\<Strava-Client-Secret\>\"", "]"}]},
