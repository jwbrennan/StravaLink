 CellID->378653224,ExpressionUUID->"fc5b91ba-e25b-0541-bd17-95d846f8c8df"],

Cell["\<\
The function, when called with the correct credentials, automatically sets \
the value of:\
\>", "Notes",
 CellChangeTimes->{{3.98905762361977*^9, 3.9890576547912827`*^9}},
 CellID->76990207,ExpressionUUID->"204af9b0-e515-da45-9411-c7020a51c6ac"],

