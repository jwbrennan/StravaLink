  RowBox[{"routes", "=", 
   RowBox[{"RandomSample", "[", 
    RowBox[{
     RowBox[{"StravaRoutes", "[", "]"}], ",", "3"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
