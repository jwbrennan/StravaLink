 CellLabel->"In[1]:=",
 CellID->488032692,ExpressionUUID->"1b9319b9-e9b6-a64a-932c-7d9423533f82"],

Cell[TextData[{
 "Copy the sequence of letters and numbers on the right-hand-side of \
\"code=abc123\" in the query string of the redirect URL and set it as the \
following ",
 ButtonBox["SystemCredential",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SystemCredential"],
 ":"
}], "ExampleText",
 CellChangeTimes->{{3.989057022252783*^9, 3.98905708563398*^9}, {
  3.989057211463661*^9, 3.989057236808502*^9}, {3.989057269294445*^9, 
  3.989057281580965*^9}},
 CellID->60786643,ExpressionUUID->"47407686-bd3a-6645-8b28-3a1e737d817d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SystemCredential", "[", "\"\<Strava-Authorization-Code\>\"", "]"}],
   "=", "\"\<abc123\>\""}]], "Input",
 CellChangeTimes->{{3.989057249526911*^9, 3.989057251591017*^9}, {
  3.9890578682039185`*^9, 3.9890578751913357`*^9}},
 CellLabel->"In[2]:=",
