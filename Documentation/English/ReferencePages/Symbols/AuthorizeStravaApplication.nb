Notebook[{

Cell[CellGroupData[{
Cell["AuthorizeStravaApplication", "ObjectName",
 CellID->959782555,ExpressionUUID->"68375756-c9a7-5d4f-8a89-1ad8007815f8"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"a25d7ef3-c7b9-7043-a0c8-1bb4aea0061b"],
 Cell[BoxData[
  RowBox[{"AuthorizeStravaApplication", "[", "]"}]], "InlineFormula",
  ExpressionUUID->"59bafc23-8b58-164c-a640-0078a1c73d0f"],
 " \[LineSeparator]opens a browser window to allow authorization and obtain \
an authorization code\n",
 Cell["   ", "ModInfo",ExpressionUUID->"668148a7-5638-bc41-82c6-b5fd2ff5be08"],
 Cell[BoxData[
  RowBox[{"AuthorizeStravaApplication", "[", 
   StyleBox[
    RowBox[{"redirectURI", ",", " ", "scope"}], "TI"], "]"}]], 
  "InlineFormula",ExpressionUUID->"5bbff23c-850f-6048-9ad3-e87426e7d0e8"],
 "\[LineSeparator]redirects to ",
 StyleBox["redirectURI", "TI"],
 " after authorization, and grants permissions specified by ",
 StyleBox["scope", "TI"]
}], "Usage",
 CellChangeTimes->{{3.9890562086852226`*^9, 3.989056289078474*^9}, {
  3.989056393268984*^9, 3.9890564786626472`*^9}},
 CellID->400961377,ExpressionUUID->"6dac890f-7912-b543-88b5-f2ad86cc099c"],

Cell["\<\
The purpose of this function is to construct a URL which directs you to an \
OAuth page. After authorizing, you will be redirected to a URL which includes \
your Authorization Code in the query string, (e.g., code=abc123).\
\>", "Notes",
 CellChangeTimes->{{3.989056520094776*^9, 3.9890565976148205`*^9}, {
  3.989056639517479*^9, 3.989056649231449*^9}, {3.989093040663801*^9, 
  3.989093040664896*^9}},
 CellID->139698486,ExpressionUUID->"dba9defc-34dc-a349-9bb3-be066f548b31"],

Cell["The following arguments can be given:", "Notes",
 CellChangeTimes->{{3.989056520094776*^9, 3.9890565976148205`*^9}, {
  3.989056639517479*^9, 3.989056649231449*^9}, {3.989093041622738*^9, 
  3.9890930487682076`*^9}},
 CellID->97286203,ExpressionUUID->"6d79a87e-d785-5245-ba75-60bd57bb8f0e"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "a6f57587-41c1-754c-aa7c-6c754cef79df"], Cell[TextData[StyleBox[
    "redirectURI",
     FontSlant->"Italic"]], "TableText",ExpressionUUID->
     "08e8b98e-151b-064a-9133-9b7edf4b680c"], Cell[
    "\"http://localhost\"", "TableText",ExpressionUUID->
     "ce9ed413-4afa-f94e-8a43-c7429f702ac7"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e9e7da92-0b44-8343-a147-1ca580f6c327"], Cell[TextData[StyleBox["scope",
     FontSlant->"Italic"]], "TableText",ExpressionUUID->
     "6077d836-0b75-c545-82d6-05a6ce589d89"], Cell[
    "\"read_all,activity:read_all,profile:read_all\"", "TableText",
     ExpressionUUID->"ef302a8d-766c-2143-a6d3-a28d630c2e04"]}
  }]], "2ColumnTableMod",
