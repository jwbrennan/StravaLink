 Cell[BoxData[
  RowBox[{"RefreshStravaAccessToken", "[", "]"}]], "InlineFormula",
  ExpressionUUID->"abc11266-1b4a-2143-878b-89c202fd4b69"],
 " \[LineSeparator]executes a request for a new access token using \
authenticated athlete credentials"
}], "Usage",
 CellChangeTimes->{{3.9890579427744007`*^9, 3.9890579468278866`*^9}},
 CellID->232088568,ExpressionUUID->"3a405cfc-04ba-5041-9827-cb33ce301aee"],

