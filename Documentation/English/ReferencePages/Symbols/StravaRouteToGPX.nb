    StyleBox["id", "TI"], ",", " ", 
    StyleBox["elem", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "675685cf-8b50-7847-b035-feb60438720c"],
 "\[LineSeparator]returns the element ",
 StyleBox["elem", "TI"],
 " from a GPX file of the route identified by ",
 StyleBox["id", "TI"]
}], "Usage",
