  RowBox[{"StravaRouteToGPX", "[", 
   StyleBox["id", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "adc662e3-5383-e84d-a639-8b8a1eeba4dd"],
 " \[LineSeparator] imports a GPX file of the route identified by ",
