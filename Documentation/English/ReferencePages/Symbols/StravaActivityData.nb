Cell[BoxData[
 RowBox[{"Module", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"page", "=", "1"}], ",", "data", ",", 
     RowBox[{"totalActivities", "=", "0"}]}], "}"}], ",", 
   "\[IndentingNewLine]", "  ", 
   RowBox[{
    RowBox[{"While", "[", "\[IndentingNewLine]", "    ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"data", "=", 
         RowBox[{"StravaActivityData", "[", 
          RowBox[{"\"\<Page\>\"", "->", "page"}], "]"}]}], ";", " ", 
        RowBox[{
         RowBox[{"Length", "[", "data", "]"}], ">", "0"}]}], ")"}], ",", 
      "\[IndentingNewLine]", "    ", 
      RowBox[{
       RowBox[{"totalActivities", " ", "+=", " ", 
        RowBox[{"Length", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "30"}], ",", 
         RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{"page", "++"}], ";"}]}], "\[IndentingNewLine]", "  ", "]"}], ";",
     "\[IndentingNewLine]", "  ", "totalActivities"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
